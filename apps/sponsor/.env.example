# Lumenia sponsor service — environment (testnet sprint)
# Copy to .env for local dev; set these as project env vars when deploying.

STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org

# Hot sponsor key (Ed25519 S...). Generate + friendbot one with:
#   pnpm --filter @lumenia/sponsor bootstrap
# KMS replaces this later (see src/lib/signer.ts — proven by Spike #1b).
SPONSOR_SECRET=

# The single USDC asset the sponsor opens trustlines to.
USDC_ISSUER=
USDC_CODE=USDC

# OPTIONAL test-USDC faucet key (Ed25519 S...) — a SEPARATE key from the sponsor
# (two blast radii). Unset = POST /faucet is disabled (503). Bootstrap one with:
#   USDC_ISSUER_SECRET=S... pnpm --filter @lumenia/sponsor faucet-bootstrap
FAUCET_SECRET=

# Economic guards
FEE_BUMP_MAX_STROOPS=10000
RATE_CAP=30
RATE_WINDOW_MS=60000
ACCOUNT_RATE_CAP=5
ACCOUNT_RATE_WINDOW_MS=60000

# OPTIONAL durable cross-instance rate limit (serverless): set the Upstash Redis /
# Vercel KV REST pair and bursts 429 across instances. Unset = in-memory buckets.
#   KV_REST_API_URL=            (or UPSTASH_REDIS_REST_URL)
#   KV_REST_API_TOKEN=          (or UPSTASH_REDIS_REST_TOKEN)

# CORS: the web origin allowed to call this service from the browser.
ALLOWED_ORIGIN=https://lumenia.vercel.app

PORT=8787
