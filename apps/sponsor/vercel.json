{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node build-vercel.mjs",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/create-account", "destination": "/api/create-account" },
    { "source": "/feebump", "destination": "/api/feebump" },
    { "source": "/send-link", "destination": "/api/send-link" },
    { "source": "/faucet", "destination": "/api/faucet" },
    { "source": "/demo-link", "destination": "/api/demo-link" },
    { "source": "/waitlist", "destination": "/api/waitlist" },
    { "source": "/events", "destination": "/api/events" }
  ]
}
